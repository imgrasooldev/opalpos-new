# Copy to .env and adjust
PROJECT_NAME="OpalPos"
APP_ENV=local
DEBUG=true
BASE_URL="http://localhost:8000"

# ---------- Database ----------
# SQLite (zero-config, sirf quick local scratch ke liye):
# DATABASE_URL="sqlite+aiosqlite:///./app.db"
# PostgreSQL (asli target):
DATABASE_URL="postgresql+asyncpg://opalpos:opalpos@localhost:5432/opalpos"
DATABASE_URL_SYNC="postgresql+psycopg://opalpos:opalpos@localhost:5432/opalpos"
DB_ECHO=false
# Pool: har uvicorn worker apna pool banata hai, isliye Postgres ka
# max_connections >= workers * (POOL_SIZE + MAX_OVERFLOW) hona chahiye.
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ---------- Security ----------
SECRET_KEY="change-me-in-production-min-32-chars-long"
ACCESS_TOKEN_EXPIRE_MINUTES=60
MOBILE_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
ALLOW_LEGACY_LARAVEL_HASH=true      # purane $2y$ bcrypt hashes accept karo

# ---------- CORS ----------
# Next.js dev :3000 ; Flutter app ka koi origin nahi hota (native), isliye
# usay CORS ki zaroorat hi nahi padti.
CORS_ORIGINS='["http://localhost:3000"]'

# ---------- Redis ----------
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"
CACHE_TTL_SECONDS=300

# ---------- Rate limiting ----------
# Redis chahiye. Local dev (bina Redis) mein false rakho, warna har request
# Redis connect karne ki koshish karegi. Production mein true.
RATE_LIMIT_ENABLED=false

# ---------- Uploads ----------
UPLOAD_DIR="uploads"
STATIC_URL_PREFIX="/static"
MAX_UPLOAD_SIZE=5242880   # 5 MB

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_JSON=true

# ---------- Payments (optional) ----------
STRIPE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
AUTHORIZENET_LOGIN_ID=
AUTHORIZENET_TRANSACTION_KEY=
AUTHORIZENET_SANDBOX=true
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=

# ---------- SMS (optional) ----------
TWILIO_SID=
TWILIO_TOKEN=
VONAGE_API_KEY=
VONAGE_API_SECRET=

# ---------- Mobile push (optional) ----------
FCM_CREDENTIALS_FILE=

# ---------- Storage / backup (optional) ----------
STORAGE_DRIVER=local
AWS_S3_BUCKET=
DROPBOX_TOKEN=

# ---------- Observability (optional) ----------
SENTRY_DSN=
